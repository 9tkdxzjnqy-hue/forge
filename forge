#!/usr/bin/env bash
# forge — Forge startup wrapper
# Usage: ./forge serve
# Generates output/manifest.json, then starts the HTTP server.

set -e
cd "$(dirname "$0")"

COMMAND="${1:-serve}"

if [[ "$COMMAND" == "serve" ]]; then
  echo "==> Generating manifest..."
  python3 generate-manifest.py

  echo ""
  echo "==> Starting server at http://localhost:8080/viewer/"
  echo "    Press Ctrl+C to stop."
  echo ""
  python3 -m http.server 8080
else
  echo "Usage: ./forge serve"
  exit 1
fi
